// Translation of the VBA `RunDistributionCalculation` per-event math.
//
// One DSL rule, evaluated once per (investor, fund, quarter) tuple. The driver
// supplies each row's inputs via the DataSource keyed by canonical noun phrase:
//
//   units held quarterly   → Number      (units held at period end)
//   distribution per unit  → Money       (period DPU, kept at full precision)
//   nav per unit           → Money       (end-of-period NAV per unit)
//   withholding rate       → Percentage  (lookup: tax_class × fund strategy)
//   reinvest preference    → Boolean     (true if investor pref = "Reinvest")
//
// Money arithmetic preserves DECIMAL64 precision through the rule body; the
// platform layer can apply `Money.rounded()` at the output boundary if it
// wants currency-fraction-digit display.
rule "Quarterly Distribution Event" {
  description: "Per-(investor, fund, quarter) NAV-based income distribution: gross income, withholding tax, net payout, and optional reinvestment in units."
  applies to: investor
  effective: from 2025-01-01 to 2025-12-31

  let u    = units held quarterly
  let dpu  = distribution per unit
  let nav  = nav per unit
  let rate = withholding rate

  let gross       = u * dpu
  let tax         = gross * rate
  let net         = gross - tax
  let reinv_units = net / nav

  publish gross
  publish tax
  publish net
  publish reinv_units
}
